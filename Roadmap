Phase 4: Eloquent Relationships ++++++++++++
User
public function posts()
{
    return $this->hasMany(Post::class);
}

public function comments()
{
    return $this->hasMany(Comment::class);
}
Post
public function author()
{
    return $this->belongsTo(User::class, 'user_id');
}

public function category()
{
    return $this->belongsTo(Category::class);
}

public function comments()
{
    return $this->hasMany(Comment::class);
}

public function tags()
{
    return $this->belongsToMany(Tag::class);
}
Comment
public function author()
{
    return $this->belongsTo(User::class, 'user_id');
}

public function post()
{
    return $this->belongsTo(Post::class);
}

public function replies()
{
    return $this->hasMany(Comment::class, 'parent_id');
}
Phase 5: GraphQL Schema

Create types:

graphql  
├── schema.graphql
├── types ++++++++++++
│   ├── user.graphql
│   ├── post.graphql
│   ├── comment.graphql
│   ├── category.graphql
│   └── tag.graphql
├── queries
│   ├── user.graphql
│   ├── post.graphql
│   ├── category.graphql
│   └── tag.graphql
├── mutations
│   ├── post.graphql ++++++++++++
│   ├── comment.graphql
│   └── tag.graphql
└── inputs
    ├── post.graphql
    ├── comment.graphql
    └── tag.graphql

type User { ++++++++++++
    id: ID!
    name: String!
    email: String!
    posts: [Post!]! @hasMany
    comments: [Comment!]! @hasMany
}

type Post { ++++++++++++
    id: ID!
    title: String!
    slug: String!
    excerpt: String
    content: String!
    cover_image: String
    status: String!
    views: Int!
    author: User! @belongsTo(relation: "author")
    category: Category @belongsTo
    comments: [Comment!]! @hasMany
    tags: [Tag!]! @belongsToMany
    created_at: DateTime!
    updated_at: DateTime!
}

type Comment { ++++++++++++
    id: ID!
    content: String!
    status: String!
    author: User! @belongsTo(relation: "author")
    post: Post! @belongsTo
    replies: [Comment!]! @hasMany
}

type Category { ++++++++++++
    id: ID!
    name: String!
    slug: String!
    posts: [Post!]! @hasMany
}

type Tag { ++++++++++++
    id: ID!
    name: String!
    slug: String!
    posts: [Post!]! @belongsToMany
}
Phase 6: GraphQL Queries
Basic queries
type Query {
    posts(
        title: String @where(operator: "like")
        status: String @eq
    ): [Post!]! @paginate(defaultCount: 10)

    post(id: ID! @eq): Post @find

    postBySlug(slug: String! @eq): Post @find

    categories: [Category!]! @all

    tags: [Tag!]! @all

    me: User @auth
}

Example:

query {
  posts(status: "published", first: 10) {
    data {
      id
      title
      slug
      author {
        name
      }
      category {
        name
      }
    }
    paginatorInfo {
      total
      currentPage
      lastPage
    }
  }
}
Phase 7: GraphQL Mutations ++++++++++++
Create post
type Mutation {
    createPost(
        title: String! @rules(apply: ["required", "string", "min:5", "max:255"])
        slug: String! @rules(apply: ["required", "string", "unique:posts,slug"])
        excerpt: String
        content: String! @rules(apply: ["required", "string", "min:20"])
        cover_image: String
        status: String! @rules(apply: ["required", "in:draft,published"])
        category_id: ID
    ): Post! @create
}
Update post
extend type Mutation {
    updatePost(
        id: ID! @whereKey
        title: String
        slug: String
        excerpt: String
        content: String
        cover_image: String
        status: String @rules(apply: ["in:draft,published,archived"])
        category_id: ID
    ): Post! @update
}
Delete post ++++++++++++
extend type Mutation {
    deletePost(
        id: ID! @whereKey
    ): Post @delete
}
Phase 8: REST File Upload  ++++++++++++

Use REST for uploads.

POST /api/upload/post-cover
POST /api/upload/avatar

Example response:

{
  "url": "/storage/posts/cover.jpg",
  "path": "posts/cover.jpg"
}

Then save the returned path inside GraphQL:

mutation {
  createPost(
    title: "GraphQL in Laravel"
    slug: "graphql-in-laravel"
    content: "Long content..."
    cover_image: "posts/cover.jpg"
    status: "published"
  ) {
    id
    title
    cover_image
  }
}
